# ==============================
# CLOUDINARY
# ==============================

CLOUDINARY_CLOUD_NAME=seu_cloud_name
CLOUDINARY_API_KEY=sua_api_key
CLOUDINARY_API_SECRET=seu_api_secret

# ==============================
# META / INSTAGRAM GRAPH API
# ==============================

GRAPH_API_VERSION=v24.0
INSTAGRAM_USER_ID=seu_instagram_user_id
INSTAGRAM_ACCESS_TOKEN=seu_token_da_meta

# ==============================
# MODO DE EXECUÇÃO
# ==============================

# true  = simula a publicação no Instagram, sem chamar a API real
# false = usa a Instagram Graph API real
MOCK_INSTAGRAM=true

# ==============================
# WORKER
# ==============================

QUEUE_FILE=data/posts_queue.json
WORKER_INTERVAL_SECONDS=15